DATABASE_URL=postgresql://openwhen:openwhen_dev@localhost:5432/openwhen

FIREBASE_PROJECT_ID=
# 二擇一：
#   (A) 本機放金鑰檔，用此路徑（預設）
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
#   (B) 直接給整份 JSON 字串（單行），優先於 (A)。
#       用 `railway run` 開發時 Railway 會自動注入，本機就不需要金鑰檔。
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

GEMINI_API_KEY=

SECRET_KEY=change-me-in-production

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8081

# Email 通知用 Brevo HTTP API（免費、不需網域、走 HTTPS）
# 在 Brevo 後台建立 API key，並把 MAIL_FROM_EMAIL 設為已驗證的寄件人
BREVO_API_KEY=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=OpenWhen

# 管理員 email，可手動觸發通知 POST /admin/check-notifications
ADMIN_EMAIL=
