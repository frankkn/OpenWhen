DATABASE_URL=postgresql://openwhen:openwhen_dev@localhost:5432/openwhen

FIREBASE_PROJECT_ID=
# 二擇一：
#   (A) 本機放金鑰檔，用此路徑（預設）
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
#   (B) 直接給整份 JSON 字串（單行），優先於 (A)。
#       用 `railway run` 開發時 Railway 會自動注入，本機就不需要金鑰檔。
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

GEMINI_API_KEY=

SECRET_KEY=change-me-in-production

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8081

# Email 通知用 Gmail SMTP（免費，不需網域）
# 需先在 Google 帳號開啟兩步驟驗證，再到「應用程式密碼」產生 16 碼密碼
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# 管理員 email，可手動觸發通知 POST /admin/check-notifications
ADMIN_EMAIL=
